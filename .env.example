# Sample environment variables for Discord bot
DISCORD_TOKEN=your_token_here
DISCORD_GUILD_IDS=123456789012345678,987654321098765432

# Graphics Monitor: when set to true, DM the post's author instead of the moderator
# when a date format cannot be automatically detected.
# If the author has DMs disabled the bot will fall back to the moderator.
# Default: false
NOTIFY_AUTHOR_ON_DATE_MISSING=false

